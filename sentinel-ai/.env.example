# ─────────────────────────────────────────────────────────────────
# Sentinel AI — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── LLM API Keys ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Elasticsearch ─────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ES_INDEX_SYSLOG=sentinel-syslog
ES_INDEX_AUTH=sentinel-auth
ES_INDEX_NETWORK=sentinel-network
ES_INDEX_APP=sentinel-application

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=sentinel_password

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/sentinel.log

# ── Operational Modes ─────────────────────────────────────────────
# Set SIMULATION_MODE=true to use synthetic data instead of live sources
SIMULATION_MODE=false
# Set DRY_RUN=true to log mitigation actions without executing them
DRY_RUN=true

# ── Detection Thresholds ──────────────────────────────────────────
ANOMALY_THRESHOLD=0.7
CRITICAL_THRESHOLD=0.92
HIGH_THRESHOLD=0.80
MEDIUM_THRESHOLD=0.65
LOW_THRESHOLD=0.40

# ── RL Agent ──────────────────────────────────────────────────────
RL_MODEL_PATH=models/rl_agent.zip
RL_TRAINING_TIMESTEPS=100000
RL_LEARNING_RATE=0.0003
RL_N_STEPS=2048
RL_BATCH_SIZE=64
RL_N_EPOCHS=10
RL_GAMMA=0.99

# ── Vision Transformer ────────────────────────────────────────────
VIT_MODEL_PATH=models/vit_anomaly.pt
VIT_IMAGE_SIZE=224
VIT_PATCH_SIZE=16
VIT_NUM_CLASSES=5
VIT_EMBED_DIM=768
VIT_NUM_HEADS=12
VIT_NUM_LAYERS=12

# ── Ingestion ─────────────────────────────────────────────────────
INGESTION_BATCH_SIZE=100
INGESTION_POLL_INTERVAL=5
PACKET_CAPTURE_INTERFACE=eth0
PACKET_CAPTURE_FILTER=

# ── API ───────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=http://localhost:3000,http://localhost:5601

# ── SOC Alerting ──────────────────────────────────────────────────
SOC_WEBHOOK_URL=https://hooks.slack.com/services/...
SOC_EMAIL=soc-team@company.com
PAGERDUTY_INTEGRATION_KEY=
